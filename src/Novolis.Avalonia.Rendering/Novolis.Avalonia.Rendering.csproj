<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Novolis.Avalonia.Rendering</PackageId>
    <IsPackable>true</IsPackable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Description>Avalonia hosts for Novolis.Rendering.TwoD (OpenGL) and CPU RGBA frames.</Description>
    <RootNamespace>Novolis.Avalonia.Rendering</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Novolis.Math.Geometry" />
    <PackageReference Include="Novolis.Rendering.Presentation.Abstractions" />
    <PackageReference Include="Novolis.Rendering.TwoD" />
    <PackageReference Include="Novolis.Rendering.Backends.TwoD.Silk" />
    <PackageReference Include="Silk.NET.OpenGL" />
  </ItemGroup>
</Project>
